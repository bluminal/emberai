OPNSENSE_HOST=              # https://192.168.1.1 or https://fw.local
OPNSENSE_API_KEY=           # API key (Basic Auth username)
OPNSENSE_API_SECRET=        # API secret (Basic Auth password)
OPNSENSE_WRITE_ENABLED=false
OPNSENSE_VERIFY_SSL=true    # Set to "false" for self-signed certs
NETEX_CACHE_TTL=300
