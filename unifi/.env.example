# Required for Local Gateway API
UNIFI_LOCAL_HOST=         # IP or hostname of UniFi local gateway (e.g., 192.168.1.1)
UNIFI_LOCAL_KEY=          # API key for local gateway

# Optional - Cloud V1 API (Phase 2)
UNIFI_API_KEY=            # API key for Cloud V1 and Site Manager EA

# SSL Verification (default: true)
UNIFI_VERIFY_SSL=true     # Set to "false" for self-signed certs on UniFi gateways

# Write Operations (default: false)
UNIFI_WRITE_ENABLED=false # Set to "true" to enable write operations

# Cache (optional)
NETEX_CACHE_TTL=300       # Override default TTL in seconds
