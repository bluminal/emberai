# Talos Plugin Environment Variables
# ====================================

# Required: Path to the talosconfig file (contains mTLS credentials)
# Generated by: talosctl gen config or talosctl config new
TALOS_CONFIG=

# Optional: Named context within the talosconfig file
# If not set, the current context from the talosconfig is used
TALOS_CONTEXT=

# Optional: Enable write operations (default: false)
# Must be "true" to allow config apply, bootstrap, reboot, reset, upgrade, etc.
TALOS_WRITE_ENABLED=false

# Optional: Default target node IPs (comma-separated)
# Used when --nodes is not specified in tool calls
# Example: 192.168.100.10,192.168.100.11,192.168.100.12
TALOS_NODES=
