CISCO_HOST=                    # IP or hostname of the Cisco SG-300 (e.g. 192.168.1.254)
CISCO_SSH_USERNAME=            # SSH username (e.g. admin)
CISCO_SSH_PASSWORD=            # SSH password
CISCO_ENABLE_PASSWORD=         # Enable password for privileged EXEC (leave empty if not set)
CISCO_SNMP_COMMUNITY=public    # SNMP v2c community string
CISCO_WRITE_ENABLED=false      # Set to "true" to enable write operations
CISCO_VERIFY_SSH_HOST_KEY=true # Set to "false" to skip SSH host key verification
NETEX_CACHE_TTL=300            # Cache TTL in seconds (default: 300)
